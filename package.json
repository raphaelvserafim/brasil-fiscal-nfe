{
  "name": "@brasil-fiscal/nfe",
  "version": "0.1.0",
  "description": "Lib open-source para emissao de NFe (Nota Fiscal Eletronica) em TypeScript. Arquitetura limpa, zero dependencias, plugavel.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "tsx --test tests/**/*.spec.ts",
    "test:e2e": "tsx --test tests/e2e/*.e2e.ts",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public --registry=https://registry.npmjs.org",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com",
    "publish:all": "npm run publish:npm && npm run publish:github"
  },
  "keywords": [
    "nfe",
    "nota-fiscal",
    "sefaz",
    "fiscal",
    "brasil",
    "typescript",
    "xml",
    "certificado-digital",
    "a1",
    "danfe"
  ],
  "author": "Raphael Serafim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brasil-fiscal/nfe.git"
  },
  "bugs": {
    "url": "https://github.com/brasil-fiscal/nfe/issues"
  },
  "homepage": "https://github.com/brasil-fiscal/nfe#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "pdfkit": "^0.18.0",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "pdfkit": ">=0.13.0"
  },
  "peerDependenciesMeta": {
    "pdfkit": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
